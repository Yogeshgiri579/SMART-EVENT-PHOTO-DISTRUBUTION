# Server
PORT=5000
NODE_ENV=development

# MongoDB (use Atlas free tier or local)
MONGODB_URI=mongodb://localhost:27017/momentdrop

# Redis (Docker Desktop - local)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AWS Rekognition (free tier: 5000 images/month for 12 months)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3-compatible storage (use MinIO in Docker for free, or AWS S3)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=momentdrop
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false
# For AWS S3 leave S3_ENDPOINT empty and set AWS credentials above
